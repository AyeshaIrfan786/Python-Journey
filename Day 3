## 💻 Project Code

```python
import random

def get_computer_choice():
    return random.randint(0, 2)

def get_user_choice():
    user_input = input("Enter s (snake), w (water), g (gun): ")
    choices = {"s": 0, "w": 1, "g": 2}
    
    if user_input not in choices:
        print("Invalid input!")
        return None
    
    return choices[user_input]

def determine_winner(comp, user):
    if comp == user:
        return "Draw"
    elif (comp == 0 and user == 1) or \
         (comp == 1 and user == 2) or \
         (comp == 2 and user == 0):
        return "You Lose!"
    else:
        return "You Win!"

def display_choice(choice):
    reverse = {0: "Snake", 1: "Water", 2: "Gun"}
    return reverse[choice]

# Game starts here
computer = get_computer_choice()
user = get_user_choice()

if user is not None:
    print(f"Computer chose {display_choice(computer)}")
    result = determine_winner(computer, user)
    print(result)
```

